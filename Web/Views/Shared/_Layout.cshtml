<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Cadastro Advogados</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <style>

        .navbar-header {
            padding: 10px 0;
            display: flex;
            align-items: center;
        }

        .btn-inicio {
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 8px 20px;
        }
    </style>
</head>
<body>
    <div class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">
            <div class="navbar-header">
                <a href="@Url.Action("Index", "Advogado")" class="btn btn-primary btn-inicio">
                    Início
                </a>
            </div>
            <div class="nav navbar-nav navbar-right" style="margin-top: 15px;">
                <span class="text-muted" style="color: #9d9d9d;">CRUD de Advogados</span>
            </div>
        </div>
    </div>

    <div class="container body-content" style="margin-top: 70px;">
        @RenderBody()
        <hr />
        <footer>
            <p>@DateTime.Now.Year</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <script src="~/Scripts/app/Advogado/AdvogadoViewModel.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>